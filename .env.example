# Site
NEXT_PUBLIC_SITE_URL=https://prodlog.app
NEXT_PUBLIC_OG_IMAGE=

# Sanity (required for content)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# Sanity write token — migration script only, never commit or expose to client
SANITY_API_WRITE_TOKEN=

# Supabase (read-only anon key; server-side reads for /p/[username] portfolios)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Resend — support-request confirmation email (runtime only, set in Dokploy env;
# optional: email is skipped when unset)
RESEND_API_KEY=
